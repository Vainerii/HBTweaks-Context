{
	"schemaVersion": 1,
	"id": "hb-tweaks",
	"version": "${version}",
	"name": "HB Tweaks",
	"description": "Ajoute des fonctionnalités spéciales pour hb",
	"authors": [
		"Vaïnerii"
	],
	"contact": {
